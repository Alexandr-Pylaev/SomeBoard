# Settings for backend
BACKEND_HTTP_PORT=9001
# Remove # from docker-compose.yml if you want to use https
# BACKEND_HTTPS_PORT=9000
# BACKEND_CERT_PATH=./backend/cert.crt
BACKEND_CONFIG=./backend/config.json
BACKEND_LOGS=./backend/logs/
BACKEND_ADMINSECRET=./backend/admin.secret

# Settings for frontend
FRONTEND_HTTP_PORT=80
# Remove # from docker-compose.yml if you want to use https
# FRONTEND_HTTPS_PORT=443
# FRONTEND_CERT_PATH=./frontend/cert.crt
FRONTEND_CONFIG=./frontend/config.json
FRONTEND_LOGS=./frontend/logs/

# Settings for database
DATABASE_USERNAME=postgres
DATABASE_NAME=someboard
DATABASE_PASSWORD="[ENTER YOUR PASSWORD]"
DATABASE_PASSFILE="[OR USE POSTGRES .pgpass FILE]"